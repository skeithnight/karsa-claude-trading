{
  "dashboard": {
    "title": "Karsa Crypto Trading",
    "timezone": "browser",
    "refresh": "30s",
    "time": {"from": "now-6h", "to": "now"},
    "tags": ["karsa", "crypto"],
    "panels": [
      {
        "title": "Risk Profile",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [{"expr": "karsa_active_risk_profile", "refId": "A"}],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "Conservative", "color": "green"}, "1": {"text": "Semi-Aggressive", "color": "yellow"}, "2": {"text": "Aggressive", "color": "red"}}}
            ],
            "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 2, "color": "red"}]}
          }
        }
      },
      {
        "title": "Universe Size",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [{"expr": "karsa_universe_size", "refId": "A"}],
        "fieldConfig": {
          "defaults": {
            "min": 0, "max": 20,
            "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 5, "color": "yellow"}, {"value": 8, "color": "green"}]}
          }
        }
      },
      {
        "title": "Rejection Rate %",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [{"expr": "rate(karsa_signal_rejections_total[1h]) / (rate(karsa_signals_executed_total[1h]) + rate(karsa_signal_rejections_total[1h])) * 100", "refId": "A"}],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 50, "color": "yellow"}, {"value": 80, "color": "red"}]}
          }
        }
      },
      {
        "title": "Signals Executed/hr",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [{"expr": "rate(karsa_signals_executed_total[1h])", "refId": "A"}],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "fixed", "fixedColor": "green"},
            "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0.1, "color": "green"}]}
          }
        }
      },
      {
        "title": "Universe Refresh",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [{"expr": "rate(karsa_universe_refresh_total{status=\"success\"}[1h])", "legendFormat": "OK", "refId": "A"}],
        "fieldConfig": {
          "defaults": {
            "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0.01, "color": "green"}]}
          }
        }
      },
      {
        "title": "Signal Acceptance vs Rejection",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {"expr": "rate(karsa_signals_executed_total[1h])", "legendFormat": "Executed", "refId": "A"},
          {"expr": "rate(karsa_signal_rejections_total[1h])", "legendFormat": "Rejected", "refId": "B"}
        ],
        "fieldConfig": {
          "defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}},
          "overrides": [
            {"matcher": {"id": "byName", "options": "Executed"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
            {"matcher": {"id": "byName", "options": "Rejected"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
          ]
        }
      },
      {
        "title": "Rejection Reasons",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 4},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [{"expr": "sum by (reason) (increase(karsa_signal_rejections_total[6h]))", "legendFormat": "{{reason}}", "refId": "A"}],
        "options": {"legend": {"displayMode": "table", "placement": "right"}, "pieType": "donut"}
      },
      {
        "title": "Top Coin Scores",
        "type": "table",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 4},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [{"expr": "topk(10, karsa_universe_coin_score)", "legendFormat": "{{ticker}}", "refId": "A", "format": "table", "instant": true}],
        "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true}, "renameByName": {"ticker": "Coin", "Value": "Score"}}}]
      },
      {
        "title": "Signal Confidence P50 / P95",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(karsa_signal_confidence_bucket[1h]))", "legendFormat": "P50", "refId": "A"},
          {"expr": "histogram_quantile(0.95, rate(karsa_signal_confidence_bucket[1h]))", "legendFormat": "P95", "refId": "B"}
        ],
        "fieldConfig": {"defaults": {"min": 0, "max": 100, "unit": "percent", "custom": {"fillOpacity": 5, "lineWidth": 2}}}
      },
      {
        "title": "Position Size P50 / P95",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(karsa_position_size_pct_bucket[1h]))", "legendFormat": "P50", "refId": "A"},
          {"expr": "histogram_quantile(0.95, rate(karsa_position_size_pct_bucket[1h]))", "legendFormat": "P95", "refId": "B"}
        ],
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "custom": {"fillOpacity": 5, "lineWidth": 2}}}
      }
    ]
  }
}
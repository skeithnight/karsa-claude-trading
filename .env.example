# =============================================================================
# KARSA TRADING SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required: Variables marked with [REQUIRED] must be set
# Optional: Variables with defaults can be left empty
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE & STATE
# -----------------------------------------------------------------------------
# [REQUIRED] PostgreSQL password (min 12 characters)
DB_PASSWORD=your_secure_password_here_min_12_chars

# [REQUIRED] Redis password
REDIS_PASSWORD=your_redis_password_here

# Redis URL (default: redis://redis:6379)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# Postgres URL (default: postgresql://trader:${DB_PASSWORD}@postgres:5432/trading)
POSTGRES_URL=postgresql://trader:${DB_PASSWORD}@postgres:5432/trading

# Redis key prefix (default: karsa)
REDIS_PREFIX=karsa

# -----------------------------------------------------------------------------
# 9ROUTER / LLM CONFIGURATION
# -----------------------------------------------------------------------------
# Enable/disable 9Router (default: true)
9ROUTER_ENABLED=true

# [REQUIRED] 9Router base URL
9ROUTER_BASE_URL=http://karsa-9router:20128/v1

# [REQUIRED] 9Router auth token
9ROUTER_AUTH_TOKEN=

# [REQUIRED] LLM model to use
9ROUTER_MODEL=

# -----------------------------------------------------------------------------
# BYBIT (CRYPTO) - [REQUIRED] for crypto trading
# -----------------------------------------------------------------------------
# [REQUIRED] Bybit API credentials
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Use Bybit testnet (default: true) - SET TO false FOR LIVE TRADING
BYBIT_TESTNET=true

# Bybit proxy (default: socks5h://warp:1080)
BYBIT_PROXY=socks5h://warp:1080

# -----------------------------------------------------------------------------
# TELEGRAM - CRYPTO BOT
# -----------------------------------------------------------------------------
# [REQUIRED] Telegram bot token for crypto notifications
CRYPTO_TELEGRAM_TOKEN=

# [REQUIRED] Telegram chat ID for crypto notifications
CRYPTO_TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# TELEGRAM - MAIN BOT (IDX/US/ETF)
# -----------------------------------------------------------------------------
# Telegram bot token for main orchestrator
TELEGRAM_TOKEN=

# Telegram chat ID for main orchestrator
TELEGRAM_CHAT_ID=

# Telegram webhook URL (empty = long-polling mode)
TELEGRAM_WEBHOOK_URL=

# Telegram webhook secret
TELEGRAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# TRADING SAFETY
# -----------------------------------------------------------------------------
# Trading mode: "paper" or "live" (default: paper)
TRADING_MODE=paper

# Crypto-only mode: skip IDX/US/ETF jobs (default: false)
CRYPTO_ONLY_MODE=false

# -----------------------------------------------------------------------------
# CRYPTO RISK PARAMETERS
# -----------------------------------------------------------------------------
# Max risk per trade as % of equity (default: 1.0)
CRYPTO_MAX_RISK_PER_TRADE_PCT=1.0

# Max position size as % of equity (default: 10.0)
CRYPTO_MAX_POSITION_PCT=10.0

# Max concurrent open positions (default: 5)
CRYPTO_MAX_CONCURRENT_POSITIONS=5

# Daily loss limit as % of equity (default: 3.0)
CRYPTO_DAILY_LOSS_LIMIT_PCT=3.0

# Max cumulative equity drawdown from peak (default: 15.0)
CRYPTO_MAX_EQUITY_DD_PCT=15.0

# Max leverage (default: 10)
CRYPTO_MAX_LEVERAGE=10

# Funding rate alert threshold (default: 0.05)
CRYPTO_FUNDING_ALERT_THRESHOLD=0.05

# Hard reject if funding > this % per 8h (default: 0.05)
CRYPTO_FUNDING_HARD_REJECT_PCT=0.05

# Max funding cost as % of target move (default: 30.0)
CRYPTO_FUNDING_DRAG_MAX_PCT=30.0

# Max stop-loss distance from entry % (default: 2.0)
CRYPTO_MAX_SL_PCT=2.0

# Stop-loss mode: "atr" or "fixed" (default: fixed)
CRYPTO_SL_MODE=fixed

# Fixed SL dollar distance from entry (default: 1.0)
CRYPTO_FIXED_SL_DISTANCE=1.0

# Liquidation warning thresholds
CRYPTO_LIQUIDATION_WARN_PCT=20.0
CRYPTO_LIQUIDATION_ALERT_PCT=10.0
CRYPTO_LIQUIDATION_FORCE_CLOSE_PCT=5.0

# -----------------------------------------------------------------------------
# EQUITIES RISK PARAMETERS
# -----------------------------------------------------------------------------
# Max portfolio risk % (default: 2.0)
MAX_PORTFOLIO_RISK_PCT=2.0

# Max position size % (default: 15.0)
MAX_POSITION_SIZE_PCT=15.0

# Daily loss limit % for equities (default: 5.0)
DAILY_LOSS_LIMIT_PCT=5.0

# Monthly cost ceiling USD (default: 300.0)
COST_MONTHLY_CEILING_USD=300.0

# Daily cost limit USD (default: 15.0)
COST_DAILY_LIMIT_USD=15.0

# -----------------------------------------------------------------------------
# RISK PROFILE
# -----------------------------------------------------------------------------
# Default risk profile: conservative, moderate, aggressive (default: conservative)
DEFAULT_RISK_PROFILE=conservative

# Enable risk profile switching (default: true)
ENABLE_RISK_PROFILE_SWITCHING=true

# -----------------------------------------------------------------------------
# BROKER & EXECUTION APIs (IDX/US)
# -----------------------------------------------------------------------------
# IDX Broker
IDX_BROKER_API_URL=
IDX_BROKER_TOKEN=

# US Broker (Alpaca)
US_BROKER_API_URL=
US_BROKER_KEY=
US_BROKER_SECRET=

# -----------------------------------------------------------------------------
# MARKET DATA APIs
# -----------------------------------------------------------------------------
# TradingView MCP URL
TRADINGVIEW_MCP_URL=direct

# IDX Data
IDX_DATA_API_URL=
IDX_DATA_API_KEY=

# Massive API (Polygon-compatible)
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com/v3

# Finnhub.io (optional fallback)
FINNHUB_API_KEY=

# -----------------------------------------------------------------------------
# AODE (Asymmetric Opportunity Discovery Engine)
# -----------------------------------------------------------------------------
# Enable AODE (default: false)
AODE_ENABLED=false

# AODE discovery interval in minutes (default: 60)
AODE_DISCOVERY_INTERVAL_MIN=60

# AODE research batch size (default: 10)
AODE_RESEARCH_BATCH_SIZE=10

# AODE minimum composite score (default: 50.0)
AODE_MIN_COMPOSITE_SCORE=50.0

# AODE max security risk score (default: 80.0)
AODE_MAX_SECURITY_RISK=80.0

# CoinGecko API key
COINGECKO_API_KEY=

# GitHub token (for AODE research)
GITHUB_TOKEN=

# Blockchain explorer API keys
ETHERSCAN_API_KEY=
SOLSCAN_API_KEY=
BSCSCAN_API_KEY=

# Enable DexScreener (default: true)
DEXSCREENER_ENABLED=true

# -----------------------------------------------------------------------------
# GRAFANA
# -----------------------------------------------------------------------------
# Grafana admin password (default: admin)
GF_SECURITY_ADMIN_PASSWORD=admin

{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": { "limit": 100, "matchAny": false, "tags": [], "type": "dashboard" },
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Kill Switch",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_kill_switch_active or vector(0)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "SAFE", "color": "green" }, "1": { "text": "HALTED", "color": "red" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "N/A", "color": "gray" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 1, "color": "red" } ] }
        }
      }
    },
    {
      "title": "Active Breakers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(karsa_circuit_breaker_active) or vector(0)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 1, "color": "red" } ] }
        }
      }
    },
    {
      "title": "WARP Proxy",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_warp_connected or vector(0)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "noValue": "N/A",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "OK", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "N/A", "color": "gray" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 1, "color": "green" } ] }
        }
      }
    },
    {
      "title": "Open Positions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_open_positions_count or vector(0)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "min": 0, "max": 5,
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 4, "color": "yellow" }, { "value": 5, "color": "red" } ] }
        }
      }
    },
    {
      "title": "Market Regime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_crypto_regime or vector(0)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "noValue": "N/A",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CHOP", "color": "gray" }, "1": { "text": "MEAN REV", "color": "blue" }, "2": { "text": "BEAR", "color": "red" }, "3": { "text": "BULL", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "N/A", "color": "gray" } } }
          ]
        }
      }
    },
    {
      "title": "Risk Profile",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_active_risk_profile or vector(0)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CONSERVATIVE", "color": "green" }, "1": { "text": "SEMI-AGGRESSIVE", "color": "yellow" }, "2": { "text": "AGGRESSIVE", "color": "red" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "N/A", "color": "gray" } } }
          ]
        }
      }
    },
    {
      "title": "Equity Curve",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_portfolio_equity_usd", "legendFormat": "Total Equity (USDT)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" },
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "currencyUSD"
        }
      }
    },
    {
      "title": "Daily PnL",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_pnl_daily_usd", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": -500, "max": 500,
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 0, "color": "green" } ] }
        }
      },
      "options": { "displayMode": "gradient", "orientation": "vertical" }
    },
    {
      "title": "Drawdown %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_drawdown_pct", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 5,
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 2, "color": "yellow" }, { "value": 3, "color": "red" } ] }
        }
      }
    },
    {
      "title": "Win Rate 7d",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_win_rate_7d * 100", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 40, "color": "yellow" }, { "value": 50, "color": "green" } ] }
        }
      }
    },
    {
      "title": "Liquidation Distance",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_liquidation_distance_pct", "format": "table", "instant": true, "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "center", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 10, "color": "yellow" }, { "value": 20, "color": "green" } ] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "ticker": "Ticker", "Value": "Distance %", "level": "Status", "side": "Direction" } } }
      ]
    },
    {
      "title": "Funding Rates",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_funding_rate_pct", "format": "table", "instant": true, "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "center", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "value": null, "color": "blue" }, { "value": 0, "color": "orange" } ] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "ticker": "Ticker", "Value": "Funding Rate" } } }
      ]
    },
    {
      "title": "Bybit API Latency P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "histogram_quantile(0.95, sum(rate(karsa_bybit_api_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P95 Latency", "refId": "A" } ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } }
      }
    },
    {
      "title": "Scheduler Job Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "rate(karsa_job_errors_total[5m])", "legendFormat": "{{job_id}}", "refId": "A" } ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "lineWidth": 2, "fillOpacity": 80 } }
      }
    },
    {
      "title": "WebSocket Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "time() - karsa_ws_last_message_timestamp_seconds", "legendFormat": "Age", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "mappings": [ { "type": "special", "options": { "match": "null", "result": { "text": "NO DATA", "color": "red" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 30, "color": "yellow" }, { "value": 60, "color": "red" } ] }
        }
      }
    },
    {
      "title": "WS Reconnects",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_ws_reconnect_total or vector(0)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 10, "color": "red" } ] }
        }
      }
    },
    {
      "title": "Daily Loss % vs Limit",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 9, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "karsa_daily_loss_pct", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 5,
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 2, "color": "yellow" }, { "value": 3, "color": "red" } ] }
        }
      }
    },
    {
      "title": "Market Order Fallback %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 15, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "rate(karsa_limit_order_fallback_total[1h]) / clamp_min(rate(karsa_order_fill_total[1h]), 0.001) * 100 or vector(0)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "noValue": "0%",
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 20, "color": "yellow" }, { "value": 50, "color": "red" } ] }
        }
      }
    },
    {
      "title": "Fill Latency P95",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "histogram_quantile(0.95, rate(karsa_order_fill_latency_seconds_bucket[1h]))", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "N/A",
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 30, "color": "yellow" }, { "value": 60, "color": "red" } ] }
        }
      }
    },
    {
      "title": "Job Freshness",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "time() - karsa_job_last_run_timestamp_seconds", "format": "table", "instant": true, "refId": "A" } ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "center", "cellOptions": { "type": "auto" } } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 300, "color": "yellow" }, { "value": 600, "color": "red" } ] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "job_id": "Job", "Value": "Stale (s)" } } }
      ]
    },
    {
      "title": "SL Breaches & Executions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(karsa_sl_breach_total[1h])", "legendFormat": "Breach: {{ticker}}", "refId": "A" },
        { "expr": "rate(karsa_sl_execution_total[1h])", "legendFormat": "Exec: {{ticker}} {{status}}", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80 } }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [ "crypto", "karsa", "v2" ],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(karsa_position_unrealized_pnl_usd, ticker)",
        "includeAll": true,
        "multi": true,
        "name": "ticker",
        "query": "label_values(karsa_position_unrealized_pnl_usd, ticker)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",

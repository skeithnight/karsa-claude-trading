{
  "title": "ASM - Core Operations",
  "tags": ["asm", "trading", "core"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {"from": "now-24h", "to": "now"},
  "uid": "asm-core-ops",
  "panels": [
    {
      "id": 1, "title": "🟢 ASM Health", "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "max(up{job=~\"karsa.*\"})", "legendFormat": "Status"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "HEALTHY", "color": "green"}}}]}}
    },
    {
      "id": 2, "title": "💰 PnL (Realized & Unrealized)", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 4, "y": 0},
      "targets": [
        {"expr": "sum(karsa_realized_pnl_total{job=~\"karsa.*\"})", "legendFormat": "Realized"},
        {"expr": "max(karsa_pnl_unrealized_usd{job=~\"karsa.*\"})", "legendFormat": "Unrealized"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 0}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "value", "graphMode": "none", "justifyMode": "auto"}
    },
    {
      "id": 3, "title": "💵 Cash & Equity", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 10, "y": 0},
      "targets": [
        {"expr": "karsa_wallet_available_usd{job=\"karsa-crypto-orchestrator\"}", "legendFormat": "Cash"},
        {"expr": "karsa_wallet_total_equity_usd{job=\"karsa-crypto-orchestrator\"}", "legendFormat": "Equity"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "blue"}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 4, "title": "📈 Active Positions", "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "targets": [{"expr": "karsa_open_positions_count{job=\"karsa-crypto-orchestrator\"}", "legendFormat": "Count", "instant": true}],
      "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}}}
    },
    {
      "id": 5, "title": "🔴 Open Positions (Live)", "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "karsa_position_unrealized_pnl_usd{job=\"karsa-crypto-orchestrator\"}", "format": "table", "instant": true, "refId": "A"},
        {"expr": "karsa_position_entry_price_usd{job=\"karsa-crypto-orchestrator\"}", "format": "table", "instant": true, "refId": "B"},
        {"expr": "karsa_position_mark_price_usd{job=\"karsa-crypto-orchestrator\"}", "format": "table", "instant": true, "refId": "C"},
        {"expr": "karsa_position_size_qty{job=\"karsa-crypto-orchestrator\"}", "format": "table", "instant": true, "refId": "D"}
      ],
      "transformations": [
        {"id": "seriesToColumns", "options": {"byField": "ticker"}},
        {"id": "organize", "options": {
          "excludeByName": {"Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true, "side 1": true, "side 2": true, "side 3": true, "side 4": true},
          "renameByName": {"ticker": "Ticker", "Value #A": "uPnL $", "Value #B": "Entry Price", "Value #C": "Current Price", "Value #D": "Size"}
        }},
        {"id": "sortBy", "options": {"sort": [{"desc": true, "displayName": "uPnL $"}]}}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "center"}}, "overrides": [{"matcher": {"id": "byName", "options": "uPnL $"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "thresholds", "value": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 0}]}}]}, {"matcher": {"id": "byName", "options": "Entry Price"}, "properties": [{"id": "unit", "value": "currencyUSD"}]}, {"matcher": {"id": "byName", "options": "Current Price"}, "properties": [{"id": "unit", "value": "currencyUSD"}]}]},
      "options": {"showHeader": true, "sortBy": [{"displayName": "uPnL $", "desc": true}]}
    },
    {
      "id": 6, "title": "📜 Trade History (Recent Closed)", "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "postgres", "uid": "postgres"},
      "targets": [
        {"rawSql": "SELECT symbol AS \"Ticker\", side AS \"Side\", entry_price AS \"Entry Price\", exit_price AS \"Exit Price\", net_pnl AS \"Realized PnL\", roi_pct AS \"ROI %\", exit_reason AS \"Exit Reason\", closed_at AS \"Closed At\" FROM closed_trades_view LIMIT 20;", "format": "table"}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "center"}}, "overrides": [{"matcher": {"id": "byName", "options": "Realized PnL"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "custom.displayMode", "value": "color-text"}, {"id": "thresholds", "value": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 0}]}}]}, {"matcher": {"id": "byName", "options": "Entry Price"}, "properties": [{"id": "unit", "value": "currencyUSD"}]}, {"matcher": {"id": "byName", "options": "Exit Price"}, "properties": [{"id": "unit", "value": "currencyUSD"}]}, {"matcher": {"id": "byName", "options": "ROI %"}, "properties": [{"id": "unit", "value": "percent"}]}]},
      "options": {"showHeader": true}
    }
  ],
  "schemaVersion": 36
}

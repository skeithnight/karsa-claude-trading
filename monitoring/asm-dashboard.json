{
  "dashboard": {
    "id": null,
    "uid": "karsa-asm-ops",
    "title": "Karsa ASM: Trading Ledger",
    "description": "Ultimate trading ledger and operational monitor for ASM",
    "tags": [
      "crypto",
      "asm",
      "trading",
      "karsa",
      "ledger"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "row",
        "title": "Heads-Up Display",
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "ASM Status",
        "description": "Current ASM operational state",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "karsa_asm_state{job=\"karsa-crypto-bot\"}",
            "legendFormat": "ASM State",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {
                    "text": "OFFLINE",
                    "color": "red"
                  }
                }
              },
              {
                "type": "value",
                "options": {
                  "1": {
                    "text": "IDLE",
                    "color": "blue"
                  }
                }
              },
              {
                "type": "value",
                "options": {
                  "2": {
                    "text": "TRADING",
                    "color": "green"
                  }
                }
              },
              {
                "type": "value",
                "options": {
                  "3": {
                    "text": "RUNNING",
                    "color": "green"
                  }
                }
              },
              {
                "type": "special",
                "options": {
                  "match": "null",
                  "result": {
                    "text": "N/A",
                    "color": "gray"
                  }
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "red"
                },
                {
                  "value": 1,
                  "color": "green"
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center",
          "textMode": "auto"
        },
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 0,
          "y": 1
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Cash & Equity",
        "description": "Real-time capital allocation overview",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "karsa_wallet_total_equity_usd{job=\"karsa-crypto-bot\"}",
            "legendFormat": "Total Equity",
            "instant": true
          },
          {
            "expr": "karsa_wallet_available_usd{job=\"karsa-crypto-bot\"}",
            "legendFormat": "Available",
            "instant": true
          },
          {
            "expr": "karsa_wallet_used_margin_usd{job=\"karsa-crypto-bot\"}",
            "legendFormat": "Margin Used",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "green"
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "textMode": "auto"
        },
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 6,
          "y": 1
        }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "PnL Breakdown",
        "description": "Realized vs Unrealized PnL",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "karsa_auto_session_realized_pnl_usd{job=\"karsa-crypto-bot\"}",
            "legendFormat": "Realized PnL",
            "instant": true
          },
          {
            "expr": "karsa_auto_session_unrealized_pnl_usd{job=\"karsa-crypto-bot\"}",
            "legendFormat": "Unrealized PnL",
            "instant": true
          },
          {
            "expr": "karsa_auto_session_realized_pnl_usd{job=\"karsa-crypto-bot\"} + karsa_auto_session_unrealized_pnl_usd{job=\"karsa-crypto-bot\"}",
            "legendFormat": "Total PnL",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "red"
                },
                {
                  "value": 0,
                  "color": "green"
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "textMode": "auto"
        },
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 12,
          "y": 1
        }
      },
      {
        "id": 5,
        "type": "gauge",
        "title": "Win Rate",
        "description": "Percentage of winning trades",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "(karsa_winning_trades_count{job=\"karsa-crypto-orchestrator\"} / clamp_min(karsa_total_trades_count{job=\"karsa-crypto-orchestrator\"}, 1)) * 100",
            "legendFormat": "Win Rate",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "red"
                },
                {
                  "value": 40,
                  "color": "yellow"
                },
                {
                  "value": 60,
                  "color": "green"
                }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "gridPos": {
          "h": 3,
          "w": 3,
          "x": 18,
          "y": 1
        }
      },
      {
        "id": 6,
        "type": "stat",
        "title": "Profit Factor",
        "description": "Gross Profit / Gross Loss",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "karsa_profit_factor{job=\"karsa-crypto-orchestrator\"}",
            "legendFormat": "PF",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "red"
                },
                {
                  "value": 1,
                  "color": "yellow"
                },
                {
                  "value": 2,
                  "color": "green"
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "textMode": "auto"
        },
        "gridPos": {
          "h": 3,
          "w": 3,
          "x": 21,
          "y": 1
        }
      },
      {
        "id": 7,
        "type": "stat",
        "title": "Total Trades",
        "description": "Executed in session",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "karsa_total_trades_count{job=\"karsa-crypto-orchestrator\"}",
            "legendFormat": "Trades",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "blue"
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "textMode": "auto"
        },
        "gridPos": {
          "h": 3,
          "w": 3,
          "x": 18,
          "y": 4
        }
      },
      {
        "id": 8,
        "type": "stat",
        "title": "Max Drawdown",
        "description": "Worst drawdown this session",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "karsa_max_drawdown_pct{job=\"karsa-crypto-orchestrator\"}",
            "legendFormat": "Max DD",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "green"
                },
                {
                  "value": 2,
                  "color": "yellow"
                },
                {
                  "value": 5,
                  "color": "red"
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "textMode": "auto"
        },
        "gridPos": {
          "h": 3,
          "w": 3,
          "x": 21,
          "y": 4
        }
      },
      {
        "id": 9,
        "type": "row",
        "title": "Financial Time-Series",
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 7
        }
      },
      {
        "id": 10,
        "type": "timeseries",
        "title": "Equity & Cash Curve",
        "description": "Track capital deployment over time",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "karsa_wallet_total_equity_usd{job=\"karsa-crypto-bot\"}",
            "legendFormat": "Total Equity",
            "refId": "A"
          },
          {
            "expr": "karsa_wallet_available_usd{job=\"karsa-crypto-bot\"}",
            "legendFormat": "Available Cash",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "auto"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "green"
                }
              ]
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Available Cash"
              },
              "properties": [
                {
                  "id": "custom.lineStyle",
                  "value": {
                    "fill": "dash",
                    "dash": [
                      10,
                      10
                    ]
                  }
                },
                {
                  "id": "color",
                  "value": {
                    "fixedColor": "gray",
                    "mode": "fixed"
                  }
                }
              ]
            }
          ]
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          },
          "tooltip": {
            "mode": "multi"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 11,
        "type": "stat",
        "title": "Daily Net PnL",
        "description": "Today's realized + unrealized PnL",
        "datasource": {
          "type": "postgres",
          "uid": "postgres"
        },
        "targets": [
          {
            "rawSql": "SELECT sum(total_pnl) AS \"Daily PnL\" FROM crypto_pnl_snapshots WHERE $__timeFilter(snapshot_date)",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "red"
                },
                {
                  "value": 0,
                  "color": "green"
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto",
          "textMode": "auto"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 12,
        "type": "row",
        "title": "The Tape \u2014 Live Data",
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 16
        }
      },
      {
        "id": 13,
        "type": "table",
        "title": "Open Positions (Live)",
        "description": "Real-time view of active positions",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "karsa_position_data{job=\"karsa-crypto-bot\"}",
            "legendFormat": "{{ticker}} {{side}} {{field}}",
            "instant": true,
            "refId": "A",
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "instance": true,
                "job": true
              },
              "renameByName": {
                "ticker": "Symbol",
                "side": "Side",
                "field": "Field"
              }
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Symbol"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "string"
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Side"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "string"
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "uPnL ($)"
              },
              "properties": [
                {
                  "id": "custom.cellOptions",
                  "value": {
                    "mode": "gradient",
                    "type": "color-background"
                  }
                },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": null,
                        "color": "red"
                      },
                      {
                        "value": 0,
                        "color": "green"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Leverage"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "short"
                }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "cellHeight": "sm",
          "footer": {
            "show": false
          }
        },
        "gridPos": {
          "h": 7,
          "w": 12,
          "x": 0,
          "y": 17
        }
      },
      {
        "id": 14,
        "type": "table",
        "title": "Trade History (Recent Closed)",
        "description": "Log of closed trades with Win/Loss indicator",
        "datasource": {
          "type": "postgres",
          "uid": "postgres"
        },
        "targets": [
          {
            "rawSql": "SELECT exit_date AS time, ticker AS \"Symbol\", side AS \"Side\", entry_price AS \"Entry\", exit_price AS \"Exit\", realized_pnl AS \"Realized PnL\", exit_reason AS \"Exit Reason\", CASE WHEN realized_pnl > 0 THEN 'WIN' ELSE 'LOSS' END AS \"Result\" FROM closed_paper_trades WHERE market = 'CRYPTO' AND $__timeFilter(exit_date) ORDER BY exit_date DESC LIMIT 50",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Result"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "string"
                },
                {
                  "id": "mappings",
                  "value": [
                    {
                      "type": "value",
                      "options": {
                        "WIN": {
                          "text": "WIN",
                          "color": "green"
                        },
                        "LOSS": {
                          "text": "LOSS",
                          "color": "red"
                        }
                      }
                    }
                  ]
                },
                {
                  "id": "custom.cellOptions",
                  "value": {
                    "mode": "basic",
                    "type": "color-background"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Realized PnL"
              },
              "properties": [
                {
                  "id": "custom.cellOptions",
                  "value": {
                    "mode": "gradient",
                    "type": "color-background"
                  }
                },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": null,
                        "color": "red"
                      },
                      {
                        "value": 0,
                        "color": "green"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "cellHeight": "sm",
          "footer": {
            "show": false
          }
        },
        "gridPos": {
          "h": 7,
          "w": 12,
          "x": 12,
          "y": 17
        }
      }
    ],
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "links": []
  },
  "overwrite": true
}

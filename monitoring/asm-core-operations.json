{
  "title": "ASM - Core Operations",
  "tags": ["asm", "trading", "core"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {"from": "now-24h", "to": "now"},
  "uid": "asm-core-ops",
  "panels": [
    {
      "id": 1, "title": "🟢 ASM Health", "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "max(up{job=~\"karsa.*\"})", "legendFormat": "Status"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "HEALTHY", "color": "green"}}}]}}
    },
    {
      "id": 2, "title": "💰 PnL (Realized & Unrealized)", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 4, "y": 0},
      "targets": [
        {"expr": "max(karsa_auto_session_realized_pnl_usd{job=~\"karsa.*\"})", "legendFormat": "Realized"},
        {"expr": "max(karsa_pnl_unrealized_usd{job=~\"karsa.*\"})", "legendFormat": "Unrealized"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 0}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "value", "graphMode": "none", "justifyMode": "auto"}
    },
    {
      "id": 3, "title": "💵 Cash & Equity", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 10, "y": 0},
      "targets": [
        {"expr": "max(karsa_wallet_available_usd{job=~\"karsa.*\"})", "legendFormat": "Cash"},
        {"expr": "max(karsa_wallet_total_equity_usd{job=~\"karsa.*\"})", "legendFormat": "Equity"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "blue"}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 4, "title": "📈 Active Positions", "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "targets": [{"expr": "max(karsa_open_positions_count{job=\"karsa-crypto-orchestrator\"})", "legendFormat": "Count"}],
      "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}}}
    },
    {
      "id": 5, "title": "🔴 Open Positions (Live)", "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "karsa_position_unrealized_pnl_usd{job=\"karsa-crypto-orchestrator\"}", "format": "table", "instant": true, "refId": "A"},
        {"expr": "karsa_position_entry_price_usd{job=\"karsa-crypto-orchestrator\"}", "format": "table", "instant": true, "refId": "B"},
        {"expr": "karsa_position_mark_price_usd{job=\"karsa-crypto-orchestrator\"}", "format": "table", "instant": true, "refId": "C"},
        {"expr": "karsa_position_age_hours{job=\"karsa-crypto-orchestrator\"}", "format": "table", "instant": true, "refId": "D"}
      ],
      "transformations": [
        {"id": "seriesToColumns", "options": {"byField": "ticker"}},
        {"id": "organize", "options": {
          "excludeByName": {"Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true, "side 1": true, "side 2": true, "side 3": true, "side 4": true},
          "renameByName": {"ticker": "Ticker", "Value #A": "uPnL $", "Value #B": "Entry Price", "Value #C": "Current Price", "Value #D": "Duration (h)"}
        }},
        {"id": "organize", "options": {"indexByName": {"Ticker": 0, "Duration (h)": 1, "Entry Price": 2, "Current Price": 3, "uPnL $": 4}}},
        {"id": "sortBy", "options": {"sort": [{"desc": true, "displayName": "uPnL $"}]}}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "center"}}, "overrides": [{"matcher": {"id": "byName", "options": "uPnL $"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "thresholds", "value": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 0}]}}]}, {"matcher": {"id": "byName", "options": "Entry Price"}, "properties": [{"id": "unit", "value": "currencyUSD"}]}, {"matcher": {"id": "byName", "options": "Current Price"}, "properties": [{"id": "unit", "value": "currencyUSD"}]}, {"matcher": {"id": "byName", "options": "Duration (h)"}, "properties": [{"id": "unit", "value": "h"}]}]},
      "options": {"showHeader": true, "sortBy": [{"displayName": "uPnL $", "desc": true}]}
    },
    {
      "id": 6, "title": "📜 Trade History (Last 24h)", "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "karsa_trade_closed_total{job=\"karsa-crypto-orchestrator\"}", "format": "table", "instant": true}],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true}, "renameByName": {"Value #A": "Count", "result": "Result"}}},
        {"id": "sortBy", "options": {"sort": [{"desc": true, "displayName": "Count"}]}}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "center"}}, "overrides": [{"matcher": {"id": "byName", "options": "Result"}, "properties": [{"id": "mappings", "value": [{"type": "value", "options": {"loss": {"text": "LOSS", "color": "red"}, "win": {"text": "WIN", "color": "green"}}}]}]}]},
      "options": {"showHeader": true}
    },
    {
      "id": 7, "title": "🛡️ Exit Reasons", "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "targets": [{"expr": "sum by (zone) (karsa_perf_gate_zone_total{job=\"karsa-crypto-orchestrator\"})", "legendFormat": "{{zone}}"}],
      "options": {"pieType": "donut", "legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 8, "title": "🤖 AI Actions", "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
      "targets": [{"expr": "sum by (action) (karsa_ai_judge_decisions_total{job=\"karsa-crypto-orchestrator\"})", "legendFormat": "{{action}}"}],
      "options": {"pieType": "donut", "legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 9, "title": "💼 Position Proportion", "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
      "targets": [{"expr": "sum by (ticker) (karsa_position_size_qty{job=\"karsa-crypto-orchestrator\"})", "legendFormat": "{{ticker}}"}],
      "options": {"pieType": "donut", "legend": {"displayMode": "table", "placement": "right"}}
    }
  ],
  "schemaVersion": 36
}
